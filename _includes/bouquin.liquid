---
layout: shape.liquid
---

<div class="menu"><a href="/">← retour à la liste</a></div>
<h1 class="bouquin">{{ title }}</h1>
<div class="sub-header">
  <div class="author">
    {% if author %}
      de {{ author }}
    {% endif %}
    {% if playtime %}
      ~ {{ playtime }}
    {% endif %}
  </div>
  <div class="rating-system">
    {% for rate in (1..5) %} {% if rate <= rating %}
    {% endif %} {% endfor %}
  </div>
</div>
<div class="content">
  {{ content }}
</div>
<script>
document.addEventListener('DOMContentLoaded', function() {
  var data = {
    edit: '1',
    slug: '{{ page.fileSlug }}',
    title: '{{ title | escape }}',
    rating: '{{ rating }}',
    date: '{{ date | date: "%Y-%m-%d" }}',
    type: '{% if author %}book{% else %}game{% endif %}',
    author: '{{ author | default: "" | escape }}',
    playtime: '{{ playtime | default: "" | escape }}'
  };
  var contentEl = document.querySelector('.content');
  var reviewText = contentEl ? contentEl.textContent.trim() : '';
  var params = new URLSearchParams(data);
  if (reviewText) params.set('review', reviewText);
  var footer = document.querySelector('.footer .footer-actions');
  var editLink = document.createElement('a');
  editLink.href = '/ajouter?' + params.toString();
  editLink.className = 'footer-edit';
  editLink.title = 'modifier';
  editLink.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 0 512 512"><path d="M410.3 231l11.3-11.3-33.9-33.9-62.1-62.1L291.7 89.8l-11.3 11.3-22.6 22.6L58.6 322.9c-10.4 10.4-18 23.3-22.2 37.4L1 480.7c-2.5 8.4-.2 17.5 6.1 23.7s15.3 8.5 23.7 6.1l120.3-35.4c14.1-4.2 27-11.8 37.4-22.2L387.7 253.7 410.3 231zM160 399.4l-9.1 22.7c-4 3.1-8.5 5.4-13.3 6.9L59.4 452l23-78.1c1.4-4.9 3.8-9.4 6.9-13.3l22.7-9.1 0 32c0 8.8 7.2 16 16 16l32 0zM362.7 18.7L348.3 33.2 325.7 55.8 314.3 67.1l33.9 33.9 62.1 62.1 33.9 33.9 11.3-11.3 22.6-22.6 14.5-14.5c25-25 25-65.5 0-90.5L453.3 18.7c-25-25-65.5-25-90.5 0z"/></svg>';
  footer.appendChild(editLink);
});
</script>
