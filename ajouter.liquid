---

<div class="home">
  <h1>Ajouter</h1>
  <span>
    <a href="/jeux" title="jeux video"><svg xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 0 640 512"><path d="M192 64C86 64 0 150 0 256S86 448 192 448H448c106 0 192-86 192-192s-86-192-192-192H192zM496 168a40 40 0 1 1 0 80 40 40 0 1 1 0-80zM392 304a40 40 0 1 1 80 0 40 40 0 1 1 -80 0zM168 200c0-13.3 10.7-24 24-24s24 10.7 24 24v32h32c13.3 0 24 10.7 24 24s-10.7 24-24 24H216v32c0 13.3-10.7 24-24 24s-24-10.7-24-24V280H136c-13.3 0-24-10.7-24-24s10.7-24 24-24h32V200z"/></svg></a>
    <a href="/bouquins" title="lectures"><svg xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 0 576 512"><path d="M249.6 471.5c10.8 3.8 22.4-4.1 22.4-15.5V78.6c0-4.2-1.6-8.4-5-11C247.4 52 202.4 32 144 32C93.5 32 46.3 45.3 18.1 56.1C6.8 60.5 0 71.7 0 83.8V454.1c0 11.9 12.8 20.2 24.1 16.5C55.6 460.1 105.5 448 144 448c33.9 0 79 14 105.6 23.5zm76.8 0C353 462 398.1 448 432 448c38.5 0 88.4 12.1 119.9 22.6c11.3 3.8 24.1-4.6 24.1-16.5V83.8c0-12.1-6.8-23.3-18.1-27.6C529.7 45.3 482.5 32 432 32c-58.4 0-103.4 20-123 35.6c-3.3 2.6-5 6.8-5 11V456c0 11.4 11.7 19.3 22.4 15.5z"/></svg></a>
  </span>
</div>

<form id="review-form" class="review-form">
  <div class="form-group">
    <label for="type">Type</label>
    <div class="toggle-group">
      <button type="button" class="toggle-btn active" data-type="book">Livre</button>
      <button type="button" class="toggle-btn" data-type="game">Jeu</button>
    </div>
  </div>

  <div class="form-group">
    <label for="title">Titre</label>
    <input type="text" id="title" name="title" required placeholder="Ex: Hyperion" />
  </div>

  <div class="form-group" id="author-group">
    <label for="author">Auteur</label>
    <input type="text" id="author" name="author" placeholder="Ex: Dan Simmons" />
  </div>

  <div class="form-group" id="playtime-group" style="display:none;">
    <label for="playtime">Temps de jeu</label>
    <input type="text" id="playtime" name="playtime" placeholder="Ex: 40h" />
  </div>

  <div class="form-group">
    <label>Note</label>
    <div class="star-rating" id="star-rating">
      <button type="button" class="star" data-value="1">&#9733;</button>
      <button type="button" class="star" data-value="2">&#9733;</button>
      <button type="button" class="star" data-value="3">&#9733;</button>
      <button type="button" class="star" data-value="4">&#9733;</button>
      <button type="button" class="star" data-value="5">&#9733;</button>
    </div>
    <input type="hidden" id="rating" name="rating" value="3" />
  </div>

  <div class="form-group">
    <label for="review">Avis <span class="optional">(optionnel)</span></label>
    <textarea id="review" name="review" rows="4" placeholder="Quelques mots sur cette lecture / ce jeu..."></textarea>
  </div>

  <button type="submit" class="submit-btn">Ouvrir dans GitHub</button>
</form>

<script>
(function() {
  var currentType = 'book';
  var currentRating = 3;

  // Type toggle
  var toggleBtns = document.querySelectorAll('.toggle-btn');
  toggleBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      toggleBtns.forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      currentType = btn.getAttribute('data-type');
      document.getElementById('author-group').style.display = currentType === 'book' ? '' : 'none';
      document.getElementById('playtime-group').style.display = currentType === 'game' ? '' : 'none';
    });
  });

  // Star rating
  var stars = document.querySelectorAll('.star');
  function updateStars(val) {
    currentRating = val;
    document.getElementById('rating').value = val;
    stars.forEach(function(s) {
      s.classList.toggle('selected', parseInt(s.getAttribute('data-value')) <= val);
    });
  }
  stars.forEach(function(s) {
    s.addEventListener('click', function() {
      updateStars(parseInt(s.getAttribute('data-value')));
    });
  });
  updateStars(3);

  // Form submit
  document.getElementById('review-form').addEventListener('submit', function(e) {
    e.preventDefault();
    var title = document.getElementById('title').value.trim();
    var review = document.getElementById('review').value.trim();
    var slug = title.toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-|-$/g, '');

    var frontmatter = '---\ntitle: ' + title + '\ndate: ' + new Date().toISOString().split('T')[0] + '\nrating: ' + currentRating + '\n';

    if (currentType === 'book') {
      var author = document.getElementById('author').value.trim();
      frontmatter += 'author: ' + author + '\n';
    } else {
      var playtime = document.getElementById('playtime').value.trim();
      frontmatter += 'playtime: ' + playtime + '\n';
    }

    frontmatter += '---\n';
    if (review) {
      frontmatter += '\n' + review;
    }

    var folder = currentType === 'book' ? 'books' : 'games';
    var url = 'https://github.com/XavierJp/Listes/new/master/data/' + folder
      + '?filename=' + encodeURIComponent(slug + '.md')
      + '&value=' + encodeURIComponent(frontmatter);

    window.open(url, '_blank');
  });
})();
</script>
